{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /usr/share/caddy
	encode gzip

	# Public API surface, reached through v2x.tools (same-origin → no CORS).
	# Split after the hub detach:
	#   - legacy non-V2X cruft stays on v2x-tools-backend (contact form, stats, monitoring/Telegram)
	#   - everything else (convert/generate/messages/aliases/modules) goes to the v2x-tools-hub service
	# More-specific matchers must come before the catch-all /api/*.
	@legacy path /api/contact* /api/access-stats* /api/monitoring*
	handle @legacy {
		reverse_proxy https://v2x-tools-backend-production.up.railway.app {
			header_up Host v2x-tools-backend-production.up.railway.app
		}
	}

	handle /api/* {
		reverse_proxy https://v2x-tools-hub-production.up.railway.app {
			header_up Host v2x-tools-hub-production.up.railway.app
		}
	}

	# Everything else is the static site.
	handle {
		file_server {
			hide Caddyfile
		}
	}
}
