{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /usr/share/caddy
	encode gzip

	# Public API surface, reached through v2x.tools (same-origin → no CORS).
	# Upstreams use Railway PRIVATE networking (<service>.railway.internal:8080 — the port each app's
	# Tomcat binds). No Host rewrite needed internally (no public edge in the path). If private networking
	# ever breaks, revert to the public URLs: https://v2x-tools-{hub,backend}-production.up.railway.app
	# (with `header_up Host <that-domain>`).
	# Split after the hub detach:
	#   - legacy non-V2X cruft stays on v2x-tools-backend (contact form, stats, monitoring/Telegram)
	#   - everything else (convert/generate/messages/aliases/modules) goes to the v2x-tools-hub service
	@legacy path /api/contact* /api/access-stats* /api/monitoring*
	handle @legacy {
		reverse_proxy http://v2x-tools-backend.railway.internal:8080
	}

	# Identity service (v2x-tools-users): OAuth login dance + me/redeem + JWKS. The JWKS lives at
	# /api/auth/.well-known/jwks.json, covered by /api/auth/*. Must come before the generic /api/* below.
	@auth path /api/auth/*
	handle @auth {
		reverse_proxy http://v2x-tools-users.railway.internal:8095
	}

	handle /api/* {
		reverse_proxy http://v2x-tools-hub.railway.internal:8080
	}

	# Everything else is the static site (Vite dist). Real files win first, then
	# directory index (so /doc/ → /doc/index.html), then SPA fallback to index.html.
	handle {
		try_files {path} {path}/index.html /index.html
		file_server
	}
}
